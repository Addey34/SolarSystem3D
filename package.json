{
  "name": "package",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "format": "prettier --write \"src/**/*.{ts,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,css}\"",
    "verify": "tsc --noEmit && vitest run"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^25.9.1",
    "@types/three": "^0.184.1",
    "playwright": "^1.61.1",
    "prettier": "^3.9.5",
    "typescript": "^6.0.3",
    "vite": "^6.3.1",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@tweenjs/tween.js": "^25.0.0",
    "astronomy-engine": "^2.1.19",
    "three": "^0.176.0"
  }
}
